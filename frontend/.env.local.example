# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Optional: Python detection microservice ───────────────────
# Leave empty to use the built-in demo mock
# Set to your FastAPI URL if you deploy the Python service
DETECTION_SERVICE_URL=

# ── Dev: skip Supabase Storage uploads + detection_logs inserts ─
# Useful when iterating locally on video uploads — each frame would
# otherwise upload a JPG and hit Supabase's free-tier rate limits.
# Set to "true" to bypass persistence entirely (detections still run).
SKIP_DETECTION_PERSIST=false
